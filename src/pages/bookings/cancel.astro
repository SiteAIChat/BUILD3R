---
import MarketingLayout from '@/layouts/MarketingLayout.astro';

const API_BASE = 'https://api.vibecontrol.app';
const TITLE = 'Cancel booking';
const DESCRIPTION = 'Cancel your scheduled call.';
---

<MarketingLayout title={`${TITLE} | BUILD3R`} description={DESCRIPTION}>
  <section class="mx-auto w-full max-w-2xl px-6 py-16 md:px-8">
    <p class="inline-flex items-center gap-2 rounded-full border border-ink-200 bg-white/70 px-4 py-2 text-xs font-semibold uppercase tracking-[0.3em] text-ink-600">
      Manage booking
    </p>
    <h1 class="mt-6 text-4xl font-semibold tracking-tight text-ink-900 md:text-5xl">{TITLE}</h1>

    <div id="card" class="mt-10 rounded-2xl border border-ink-200 bg-white p-6 shadow-soft">
      <p id="status" class="text-sm text-ink-600">Loading…</p>

      <div id="details" class="hidden">
        <p class="text-sm text-ink-600">You're cancelling:</p>
        <p id="when" class="mt-1 text-base font-semibold text-ink-900"></p>
        <p id="who" class="mt-1 text-sm text-ink-600"></p>

        <label class="mt-6 block">
          <span class="text-xs font-semibold uppercase tracking-wider text-ink-500">Reason (optional)</span>
          <textarea
            id="reason"
            rows="3"
            class="mt-1 w-full rounded-lg border border-ink-200 bg-white px-3 py-2 text-sm text-ink-900 focus:border-brand-blue-500 focus:outline-none"
          ></textarea>
        </label>

        <div class="mt-6 flex flex-wrap gap-3">
          <button
            id="cancel-btn"
            type="button"
            class="inline-flex items-center justify-center rounded-full bg-red-600 px-6 py-3 text-sm font-semibold text-white shadow-soft transition hover:bg-red-500 disabled:opacity-50"
          >
            Cancel booking
          </button>
          <a
            id="reschedule-link"
            class="inline-flex items-center justify-center rounded-full border border-ink-200 px-6 py-3 text-sm font-semibold text-ink-700 transition hover:border-brand-blue-500"
          >
            Reschedule instead
          </a>
        </div>
        <p id="error" class="mt-3 hidden text-sm text-red-600"></p>
      </div>

      <div id="success" class="hidden">
        <h2 class="text-xl font-semibold text-ink-900">Booking cancelled</h2>
        <p class="mt-2 text-sm text-ink-600">Your call has been cancelled. Thanks for letting us know.</p>
      </div>
    </div>
  </section>
</MarketingLayout>

<script is:inline define:vars={{ API_BASE }}>
  (function () {
    const visitorTz = Intl.DateTimeFormat().resolvedOptions().timeZone || 'UTC';
    const params = new URLSearchParams(window.location.search);
    const token = params.get('t') || '';

    const statusEl = document.getElementById('status');
    const detailsEl = document.getElementById('details');
    const successEl = document.getElementById('success');
    const errorEl = document.getElementById('error');
    const whenEl = document.getElementById('when');
    const whoEl = document.getElementById('who');
    const reasonEl = document.getElementById('reason');
    const cancelBtn = document.getElementById('cancel-btn');
    const rescheduleLink = document.getElementById('reschedule-link');

    if (!token) {
      statusEl.textContent = 'Missing booking token. The link may be incomplete.';
      return;
    }

    rescheduleLink.href = `/bookings/reschedule?t=${encodeURIComponent(token)}`;

    function fmtFull(iso) {
      return new Intl.DateTimeFormat(undefined, {
        timeZone: visitorTz,
        weekday: 'long',
        year: 'numeric',
        month: 'long',
        day: 'numeric',
        hour: 'numeric',
        minute: '2-digit',
        timeZoneName: 'short',
      }).format(new Date(iso));
    }

    async function load() {
      try {
        const res = await fetch(
          `${API_BASE}/api/public/bookings/lookup?token=${encodeURIComponent(token)}`,
        );
        if (res.status === 404) {
          statusEl.textContent = 'Booking not found. The link may be expired.';
          return;
        }
        if (!res.ok) throw new Error(`Failed to load booking (${res.status})`);
        const json = await res.json();
        if (json.status !== 'confirmed') {
          statusEl.textContent =
            json.status === 'cancelled'
              ? 'This booking has already been cancelled.'
              : `This booking is in state "${json.status}" and cannot be cancelled.`;
          return;
        }
        whenEl.textContent = fmtFull(json.starts_at);
        const bt = json.booking_type;
        const parts = [];
        if (bt && bt.name) parts.push(bt.name);
        if (json.attendee_email_masked) parts.push(json.attendee_email_masked);
        whoEl.textContent = parts.join(' · ');
        statusEl.classList.add('hidden');
        detailsEl.classList.remove('hidden');
      } catch (e) {
        statusEl.textContent = e.message || 'Failed to load booking';
      }
    }

    cancelBtn.addEventListener('click', async () => {
      errorEl.classList.add('hidden');
      cancelBtn.disabled = true;
      cancelBtn.textContent = 'Cancelling…';
      try {
        const res = await fetch(`${API_BASE}/api/public/bookings/cancel`, {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ cancel_token: token, reason: reasonEl.value || undefined }),
        });
        if (res.status === 410) {
          errorEl.textContent = 'Booking already cancelled.';
          errorEl.classList.remove('hidden');
          return;
        }
        if (!res.ok) {
          const j = await res.json().catch(() => ({}));
          throw new Error(j.error || `Cancel failed (${res.status})`);
        }
        detailsEl.classList.add('hidden');
        successEl.classList.remove('hidden');
      } catch (e) {
        errorEl.textContent = e.message || 'Cancel failed';
        errorEl.classList.remove('hidden');
      } finally {
        cancelBtn.disabled = false;
        cancelBtn.textContent = 'Cancel booking';
      }
    });

    load();
  })();
</script>

---
import BaseLayout from '@/layouts/BaseLayout.astro';

export const prerender = false;

// Get estimate ref from query param if present
const url = new URL(Astro.request.url);
const ref = url.searchParams.get('ref') || '';

const API_BASE = 'https://api.vibecontrol.app';
const INSTALL_ID = '68bc1fef-86fd-433a-9f4e-61937d5f3241';
const SLUG = '30-min-meeting';
const DURATION = 30;
---

<BaseLayout title="Estimate Received — BUILD3R" description="Thanks for requesting an estimate. Book a call to discuss next steps.">
  <meta slot="head" name="robots" content="noindex, nofollow" />

  <main class="relative">
    <!-- Hero -->
    <section class="relative overflow-hidden">
      <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-10 bg-gradient-to-br from-brand-blue-50 via-white to-brand-purple-50"></div>
      <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-10 pattern-dots" style="--pattern-color: rgba(37, 99, 235, 0.12);"></div>

      <div class="relative mx-auto w-full max-w-3xl px-6 pb-12 pt-24 text-center md:px-8">
        <div class="mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-full bg-brand-green-100">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-brand-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
        </div>

        <h1 class="text-4xl font-semibold tracking-tight text-ink-900 md:text-5xl">
          Your estimate is on the way
        </h1>
        <p class="mt-4 text-lg leading-relaxed text-ink-600">
          We've received your project details and you'll get an email shortly with a summary of your estimate. 
          The next step? Let's talk through the specifics.
        </p>

        {ref && (
          <p class="mt-4 text-sm text-ink-400">
            Reference: <span class="font-mono text-ink-500">{ref}</span>
          </p>
        )}
      </div>
    </section>

    <!-- What happens next -->
    <section class="mx-auto w-full max-w-4xl px-6 py-12 md:px-8">
      <div class="grid gap-8 md:grid-cols-3">
        <div class="rounded-xl2 border border-ink-200/60 bg-white/90 p-6 shadow-soft text-center">
          <div class="mx-auto mb-4 flex h-10 w-10 items-center justify-center rounded-full bg-brand-blue-100 text-brand-blue-600 font-bold">1</div>
          <h3 class="font-semibold text-ink-900">Check your inbox</h3>
          <p class="mt-2 text-sm text-ink-600">You'll receive a summary of your estimate with project details and pricing range.</p>
        </div>
        <div class="rounded-xl2 border border-ink-200/60 bg-white/90 p-6 shadow-soft text-center">
          <div class="mx-auto mb-4 flex h-10 w-10 items-center justify-center rounded-full bg-brand-purple-100 text-brand-purple-600 font-bold">2</div>
          <h3 class="font-semibold text-ink-900">Book a call</h3>
          <p class="mt-2 text-sm text-ink-600">We'll discuss your goals, refine the scope, and provide a precise quote.</p>
        </div>
        <div class="rounded-xl2 border border-ink-200/60 bg-white/90 p-6 shadow-soft text-center">
          <div class="mx-auto mb-4 flex h-10 w-10 items-center justify-center rounded-full bg-brand-green-100 text-brand-green-600 font-bold">3</div>
          <h3 class="font-semibold text-ink-900">Get started</h3>
          <p class="mt-2 text-sm text-ink-600">Once aligned, we kick off within days — not weeks.</p>
        </div>
      </div>
    </section>

    <!-- Booking widget -->
    <section class="mx-auto w-full max-w-xl px-6 pb-24 md:px-8">
      <div class="rounded-xl2 border border-ink-200/60 bg-white shadow-soft overflow-hidden">
        <!-- Header -->
        <div class="border-b border-ink-200/60 bg-ink-900 p-5 text-white">
          <h2 class="text-lg font-semibold">Book your discovery call</h2>
          <p class="mt-1 text-sm text-slate-300">Pick a time that works and we'll come prepared with your estimate details.</p>
          <div class="mt-3 flex items-center gap-4 text-sm text-slate-400">
            <span class="flex items-center gap-1.5">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><circle cx="12" cy="12" r="10" stroke-width="1.5"/><path stroke-linecap="round" stroke-width="1.5" d="M12 6v6l4 2"/></svg>
              {DURATION}m
            </span>
            <span class="flex items-center gap-1.5">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><rect x="2" y="6" width="14" height="12" rx="2" stroke-width="1.5"/><path stroke-linecap="round" stroke-width="1.5" d="M22 8l-6 4 6 4V8z"/></svg>
              Google Meet
            </span>
            <span class="flex items-center gap-1.5">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><circle cx="12" cy="12" r="10" stroke-width="1.5"/><path stroke-width="1.5" d="M2 12h20M12 2a15 15 0 014 10 15 15 0 01-4 10 15 15 0 01-4-10A15 15 0 0112 2z"/></svg>
              <span id="et-tz-label"></span>
            </span>
          </div>
        </div>

        <!-- Step 1: Calendar -->
        <div id="et-step-calendar" class="p-5">
          <div id="et-loading" class="py-12 text-center text-sm text-ink-500">Loading availability...</div>
          <div id="et-calendar" class="hidden">
            <div class="flex items-center justify-between mb-4">
              <h4 id="et-month-label" class="text-base font-semibold text-ink-900"></h4>
              <div class="flex gap-1">
                <button type="button" id="et-prev-month" class="rounded-lg p-2 text-ink-400 hover:bg-ink-100 hover:text-ink-700 transition disabled:opacity-30" disabled>
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                </button>
                <button type="button" id="et-next-month" class="rounded-lg p-2 text-ink-400 hover:bg-ink-100 hover:text-ink-700 transition">
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                </button>
              </div>
            </div>
            <div class="grid grid-cols-7 gap-0 text-center text-xs font-semibold uppercase text-ink-400 mb-2">
              <span>Sun</span><span>Mon</span><span>Tue</span><span>Wed</span><span>Thu</span><span>Fri</span><span>Sat</span>
            </div>
            <div id="et-grid" class="grid grid-cols-7 gap-0"></div>
          </div>
        </div>

        <!-- Step 2: Time slots -->
        <div id="et-step-times" class="hidden p-5">
          <div class="flex items-center justify-between mb-4">
            <button type="button" id="et-back-cal" class="flex items-center gap-1 text-sm text-ink-500 hover:text-ink-700 transition">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
              Back
            </button>
            <h4 id="et-day-label" class="text-base font-semibold text-ink-900"></h4>
            <div class="flex rounded-lg border border-ink-200 text-xs font-medium overflow-hidden">
              <button type="button" id="et-12h" class="px-2.5 py-1 bg-ink-900 text-white">12h</button>
              <button type="button" id="et-24h" class="px-2.5 py-1 text-ink-500 hover:bg-ink-50">24h</button>
            </div>
          </div>
          <div id="et-times-list" class="space-y-2 max-h-[28rem] overflow-y-auto pr-1"></div>
        </div>

        <!-- Step 3: Confirm form -->
        <div id="et-step-confirm" class="hidden p-5">
          <button type="button" id="et-back-times" class="flex items-center gap-1 text-sm text-ink-500 hover:text-ink-700 transition mb-4">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
            Back
          </button>
          <h4 class="text-lg font-semibold text-ink-900 mb-3">Confirm your details</h4>
          <div class="flex flex-wrap gap-2 mb-5">
            <span class="inline-flex items-center gap-1.5 rounded-full bg-ink-100 px-3 py-1.5 text-xs font-medium text-ink-700">
              <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><rect x="3" y="4" width="18" height="18" rx="2" stroke-width="1.5"/><path stroke-width="1.5" d="M3 10h18M16 2v4M8 2v4"/></svg>
              <span id="et-confirm-date-text"></span>
            </span>
            <span class="inline-flex items-center gap-1.5 rounded-full bg-ink-100 px-3 py-1.5 text-xs font-medium text-ink-700">
              <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><circle cx="12" cy="12" r="10" stroke-width="1.5"/><path stroke-linecap="round" stroke-width="1.5" d="M12 6v6l4 2"/></svg>
              {DURATION}m
            </span>
          </div>
          <form id="et-form" class="space-y-4">
            <label class="block">
              <span class="text-sm font-medium text-ink-700">Your name <span class="text-red-500">*</span></span>
              <input type="text" name="name" required class="mt-1 w-full rounded-lg border border-ink-200 bg-white px-3 py-2.5 text-sm text-ink-900 placeholder-ink-400 focus:border-brand-blue-500 focus:ring-1 focus:ring-brand-blue-500 focus:outline-none transition" placeholder="John Doe" />
            </label>
            <label class="block">
              <span class="text-sm font-medium text-ink-700">Email address <span class="text-red-500">*</span></span>
              <input type="email" name="email" required class="mt-1 w-full rounded-lg border border-ink-200 bg-white px-3 py-2.5 text-sm text-ink-900 placeholder-ink-400 focus:border-brand-blue-500 focus:ring-1 focus:ring-brand-blue-500 focus:outline-none transition" placeholder="john@example.com" />
            </label>
            <label class="block">
              <span class="text-sm font-medium text-ink-700">Additional notes</span>
              <textarea name="notes" rows="3" class="mt-1 w-full rounded-lg border border-ink-200 bg-white px-3 py-2.5 text-sm text-ink-900 placeholder-ink-400 focus:border-brand-blue-500 focus:ring-1 focus:ring-brand-blue-500 focus:outline-none transition" placeholder="Please share anything that will help prepare for our meeting."></textarea>
            </label>
            <p id="et-form-error" class="hidden text-sm text-red-600"></p>
            <div class="flex items-center justify-end gap-3 pt-2">
              <button type="button" id="et-cancel-confirm" class="px-4 py-2.5 text-sm font-medium text-ink-600 hover:text-ink-900 transition">Back</button>
              <button type="submit" id="et-submit" class="rounded-lg bg-ink-900 px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-ink-800 transition disabled:opacity-50">Confirm</button>
            </div>
          </form>
        </div>

        <!-- Step 4: Success -->
        <div id="et-step-success" class="hidden p-5">
          <div class="py-6 text-center">
            <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-brand-green-100">
              <svg class="h-6 w-6 text-brand-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            </div>
            <h4 class="text-lg font-semibold text-ink-900">Booking confirmed!</h4>
            <p id="et-success-detail" class="mt-2 text-sm text-ink-600"></p>
            <p class="mt-3 text-xs text-ink-400">Check your email for confirmation details and calendar invite.</p>
            <p id="et-success-cancel" class="mt-2 text-xs text-ink-400 break-all"></p>
          </div>
        </div>
      </div>
    </section>

    <script is:inline define:vars={{ API_BASE, INSTALL_ID, SLUG, DURATION }}>
    (function () {
      const P = "et"; // prefix for all element IDs
      const tz = Intl.DateTimeFormat().resolvedOptions().timeZone || "UTC";
      document.getElementById(P + "-tz-label").textContent = tz.replace(/_/g, " ");

      let allSlots = [], slotsByDate = new Map(), availableDates = new Set();
      let viewYear, viewMonth, selectedDate = null, selectedSlot = null, use24h = false;

      const $ = (id) => document.getElementById(id);
      const loadingEl = $(P + "-loading"), calendarEl = $(P + "-calendar"), monthLabel = $(P + "-month-label");
      const gridEl = $(P + "-grid"), prevBtn = $(P + "-prev-month"), nextBtn = $(P + "-next-month");
      const stepCalendar = $(P + "-step-calendar"), stepTimes = $(P + "-step-times");
      const stepConfirm = $(P + "-step-confirm"), stepSuccess = $(P + "-step-success");
      const dayLabel = $(P + "-day-label"), timesList = $(P + "-times-list");
      const confirmDateText = $(P + "-confirm-date-text"), formEl = $(P + "-form");
      const formError = $(P + "-form-error"), submitBtn = $(P + "-submit");
      const successDetail = $(P + "-success-detail"), successCancel = $(P + "-success-cancel");

      function ymdInTz(date) {
        const p = new Intl.DateTimeFormat("en-CA", { timeZone: tz, year: "numeric", month: "2-digit", day: "2-digit" }).formatToParts(date);
        return p.find(x => x.type === "year").value + "-" + p.find(x => x.type === "month").value + "-" + p.find(x => x.type === "day").value;
      }
      function fmtTime(iso) {
        return new Intl.DateTimeFormat(undefined, { timeZone: tz, hour: "numeric", minute: "2-digit", hour12: !use24h }).format(new Date(iso));
      }
      function fmtFullDate(iso) {
        return new Intl.DateTimeFormat(undefined, { timeZone: tz, weekday: "long", year: "numeric", month: "long", day: "numeric", hour: "numeric", minute: "2-digit" }).format(new Date(iso));
      }
      function fmtDayHeader(ymd) {
        const [y, m, d] = ymd.split("-").map(Number);
        return new Intl.DateTimeFormat(undefined, { timeZone: tz, weekday: "short", day: "numeric" }).format(new Date(Date.UTC(y, m - 1, d, 12)));
      }
      function showStep(step) {
        stepCalendar.classList.toggle("hidden", step !== "calendar");
        stepTimes.classList.toggle("hidden", step !== "times");
        stepConfirm.classList.toggle("hidden", step !== "confirm");
        stepSuccess.classList.toggle("hidden", step !== "success");
      }

      const monthNames = ["January","February","March","April","May","June","July","August","September","October","November","December"];

      function renderCalendar() {
        monthLabel.textContent = monthNames[viewMonth] + " " + viewYear;
        const today = ymdInTz(new Date());
        const todayParts = today.split("-").map(Number);
        prevBtn.disabled = (viewYear === todayParts[0] && viewMonth === todayParts[1] - 1);
        gridEl.innerHTML = "";
        const firstDay = new Date(viewYear, viewMonth, 1).getDay();
        const daysInMonth = new Date(viewYear, viewMonth + 1, 0).getDate();
        const prevMonthDays = new Date(viewYear, viewMonth, 0).getDate();
        for (let i = firstDay - 1; i >= 0; i--) {
          const c = document.createElement("div");
          c.className = "flex h-10 items-center justify-center text-sm text-ink-300";
          c.textContent = prevMonthDays - i;
          gridEl.appendChild(c);
        }
        for (let d = 1; d <= daysInMonth; d++) {
          const ymd = viewYear + "-" + String(viewMonth + 1).padStart(2, "0") + "-" + String(d).padStart(2, "0");
          const hasSlots = availableDates.has(ymd), isToday = ymd === today, isPast = ymd < today, isSelected = ymd === selectedDate;
          const cell = document.createElement("button");
          cell.type = "button"; cell.disabled = !hasSlots;
          let cls = "relative flex h-10 w-full items-center justify-center rounded-lg text-sm transition ";
          if (isSelected) cls += "bg-ink-900 text-white font-semibold ";
          else if (hasSlots) cls += "font-medium text-ink-900 hover:bg-brand-blue-50 hover:text-brand-blue-700 cursor-pointer ";
          else if (isPast) cls += "text-ink-300 cursor-default ";
          else cls += "text-ink-400 cursor-default ";
          cell.className = cls; cell.textContent = d;
          if (isToday && !isSelected) {
            const dot = document.createElement("span");
            dot.className = "absolute bottom-1 left-1/2 -translate-x-1/2 h-1 w-1 rounded-full bg-ink-900";
            cell.appendChild(dot);
          }
          if (hasSlots) cell.addEventListener("click", () => { selectedDate = ymd; renderCalendar(); renderTimes(); showStep("times"); });
          gridEl.appendChild(cell);
        }
        const totalCells = firstDay + daysInMonth;
        const remaining = (7 - (totalCells % 7)) % 7;
        for (let i = 1; i <= remaining; i++) {
          const c = document.createElement("div");
          c.className = "flex h-10 items-center justify-center text-sm text-ink-300";
          if (i === 1 && viewMonth < 11) {
            const w = document.createElement("div"); w.className = "flex flex-col items-center";
            const l = document.createElement("span"); l.className = "text-[9px] font-semibold text-ink-400 leading-none -mb-0.5";
            l.textContent = monthNames[viewMonth + 1].substring(0, 3).toUpperCase();
            const n = document.createElement("span"); n.textContent = i;
            w.appendChild(l); w.appendChild(n); c.appendChild(w);
          } else { c.textContent = i; }
          gridEl.appendChild(c);
        }
      }

      function renderTimes() {
        dayLabel.textContent = fmtDayHeader(selectedDate);
        timesList.innerHTML = "";
        for (const s of (slotsByDate.get(selectedDate) || [])) {
          const btn = document.createElement("button");
          btn.type = "button";
          btn.className = "w-full rounded-lg border border-ink-200 px-4 py-3 text-center text-sm font-medium text-ink-700 hover:border-ink-900 hover:bg-ink-900 hover:text-white transition";
          btn.textContent = fmtTime(s.starts_at);
          btn.addEventListener("click", () => { selectedSlot = s; confirmDateText.textContent = fmtFullDate(s.starts_at); showStep("confirm"); });
          timesList.appendChild(btn);
        }
      }

      $(P + "-12h").addEventListener("click", () => { use24h = false; $(P + "-12h").className = "px-2.5 py-1 bg-ink-900 text-white"; $(P + "-24h").className = "px-2.5 py-1 text-ink-500 hover:bg-ink-50"; renderTimes(); });
      $(P + "-24h").addEventListener("click", () => { use24h = true; $(P + "-24h").className = "px-2.5 py-1 bg-ink-900 text-white"; $(P + "-12h").className = "px-2.5 py-1 text-ink-500 hover:bg-ink-50"; renderTimes(); });
      $(P + "-back-cal").addEventListener("click", () => showStep("calendar"));
      $(P + "-back-times").addEventListener("click", () => showStep("times"));
      $(P + "-cancel-confirm").addEventListener("click", () => showStep("times"));
      prevBtn.addEventListener("click", () => { viewMonth--; if (viewMonth < 0) { viewMonth = 11; viewYear--; } renderCalendar(); });
      nextBtn.addEventListener("click", () => { viewMonth++; if (viewMonth > 11) { viewMonth = 0; viewYear++; } renderCalendar(); });

      formEl.addEventListener("submit", async (e) => {
        e.preventDefault();
        if (!selectedSlot) return;
        formError.classList.add("hidden"); submitBtn.disabled = true; submitBtn.textContent = "Confirming...";
        try {
          const fd = new FormData(formEl);
          const res = await fetch(API_BASE + "/api/public/bookings/" + encodeURIComponent(INSTALL_ID) + "/" + encodeURIComponent(SLUG) + "/reserve", {
            method: "POST", headers: { "content-type": "application/json" },
            body: JSON.stringify({ starts_at: selectedSlot.starts_at, ends_at: selectedSlot.ends_at, attendee: { name: fd.get("name"), email: fd.get("email"), tz: tz }, notes: fd.get("notes") || null }),
          });
          const json = await res.json().catch(() => ({}));
          if (res.status === 409) { formError.textContent = "That slot was just taken. Please pick another time."; formError.classList.remove("hidden"); submitBtn.disabled = false; submitBtn.textContent = "Confirm"; showStep("times"); await loadSlots(); return; }
          if (!res.ok) throw new Error(json.error || "Reservation failed (" + res.status + ")");
          successDetail.textContent = fmtFullDate(json.starts_at);
          if (json.cancel_url) successCancel.textContent = "Need to cancel? " + json.cancel_url;
          showStep("success");
        } catch (err) { formError.textContent = err.message || "Reservation failed"; formError.classList.remove("hidden"); }
        finally { submitBtn.disabled = false; submitBtn.textContent = "Confirm"; }
      });

      async function loadSlots() {
        try {
          const now = new Date();
          const toDate = new Date(now.getTime() + 60 * 24 * 60 * 60 * 1000);
          const res = await fetch(API_BASE + "/api/public/bookings/" + encodeURIComponent(INSTALL_ID) + "/" + encodeURIComponent(SLUG) + "/slots?from=" + now.toISOString() + "&to=" + toDate.toISOString() + "&tz=" + encodeURIComponent(tz));
          if (!res.ok) throw new Error("Failed to load availability (" + res.status + ")");
          const json = await res.json();
          if (!json.slots || json.slots.length === 0) { loadingEl.textContent = "No availability in the next 60 days. Please check back later."; return; }
          allSlots = json.slots; slotsByDate = new Map(); availableDates = new Set();
          for (const s of allSlots) { const k = ymdInTz(new Date(s.starts_at)); if (!slotsByDate.has(k)) slotsByDate.set(k, []); slotsByDate.get(k).push(s); availableDates.add(k); }
          const firstDate = Array.from(availableDates).sort()[0];
          const [fy, fm] = firstDate.split("-").map(Number);
          viewYear = fy; viewMonth = fm - 1;
          loadingEl.classList.add("hidden"); calendarEl.classList.remove("hidden"); renderCalendar();
        } catch (e) { loadingEl.textContent = e.message || "Failed to load availability"; }
      }
      loadSlots();
    })();
    </script>

    <!-- Fallback CTA -->
    <section class="mx-auto w-full max-w-3xl px-6 pb-24 text-center md:px-8">
      <div class="rounded-xl2 border border-brand-blue-100 bg-brand-blue-50/50 p-6">
        <p class="text-sm text-ink-600">
          Prefer email? No problem — just reply to the estimate email we'll send you, or reach out at
          <a href="mailto:hello@build3r.io" class="font-semibold text-brand-blue-600 underline hover:text-brand-blue-700">hello@build3r.io</a>
        </p>
      </div>
    </section>
  </main>
</BaseLayout>

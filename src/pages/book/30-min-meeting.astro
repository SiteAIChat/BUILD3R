---
import MarketingLayout from '@/layouts/MarketingLayout.astro';

const API_BASE = 'https://api.vibecontrol.app';
const INSTALL_ID = '68bc1fef-86fd-433a-9f4e-61937d5f3241';
const SLUG = '30-min-meeting';
const TITLE = '30 Min Meeting';
const DESCRIPTION = '30-minute discovery call to align on goals, constraints, and timelines.';
---

<MarketingLayout title={`${TITLE} | BUILD3R`} description={DESCRIPTION}>
  <section class="mx-auto w-full max-w-3xl px-6 py-16 md:px-8">
    <p class="inline-flex items-center gap-2 rounded-full border border-ink-200 bg-white/70 px-4 py-2 text-xs font-semibold uppercase tracking-[0.3em] text-ink-600">
      Book a call
    </p>
    <h1 class="mt-6 text-4xl font-semibold tracking-tight text-ink-900 md:text-5xl">{TITLE}</h1>
    <p class="mt-4 text-lg leading-relaxed text-ink-600">{DESCRIPTION}</p>

    <div id="booking-app" class="mt-10 rounded-2xl border border-ink-200 bg-white p-6 shadow-soft">
      <p id="booking-status" class="text-sm text-ink-600">Loading availability...</p>

      <div id="picker" class="hidden">
        <div class="flex flex-col gap-6 md:flex-row">
          <div class="md:w-48">
            <h3 class="mb-2 text-xs font-semibold uppercase tracking-wider text-ink-500">Date</h3>
            <div id="date-list" class="flex max-h-80 flex-col gap-1 overflow-y-auto"></div>
          </div>
          <div class="flex-1">
            <h3 class="mb-2 text-xs font-semibold uppercase tracking-wider text-ink-500">Time</h3>
            <div id="time-grid" class="grid grid-cols-3 gap-2 md:grid-cols-4"></div>
          </div>
        </div>
      </div>

      <form id="confirm-form" class="mt-6 hidden space-y-4 border-t border-ink-200 pt-6">
        <div>
          <p class="text-sm text-ink-600">Selected:</p>
          <p id="selected-label" class="text-base font-semibold text-ink-900"></p>
        </div>
        <div class="grid grid-cols-1 gap-3 md:grid-cols-2">
          <label class="block">
            <span class="text-xs font-semibold uppercase tracking-wider text-ink-500">Your name</span>
            <input
              type="text"
              name="name"
              required
              class="mt-1 w-full rounded-lg border border-ink-200 bg-white px-3 py-2 text-sm text-ink-900 focus:border-brand-blue-500 focus:outline-none"
            />
          </label>
          <label class="block">
            <span class="text-xs font-semibold uppercase tracking-wider text-ink-500">Email</span>
            <input
              type="email"
              name="email"
              required
              class="mt-1 w-full rounded-lg border border-ink-200 bg-white px-3 py-2 text-sm text-ink-900 focus:border-brand-blue-500 focus:outline-none"
            />
          </label>
        </div>
        <label class="block">
          <span class="text-xs font-semibold uppercase tracking-wider text-ink-500">Notes (optional)</span>
          <textarea
            name="notes"
            rows="3"
            class="mt-1 w-full rounded-lg border border-ink-200 bg-white px-3 py-2 text-sm text-ink-900 focus:border-brand-blue-500 focus:outline-none"
          ></textarea>
        </label>
        <button
          type="submit"
          id="confirm-btn"
          class="inline-flex items-center justify-center rounded-full bg-brand-blue-600 px-6 py-3 text-sm font-semibold text-white shadow-soft transition hover:bg-brand-blue-500 disabled:opacity-50"
        >
          Confirm booking
        </button>
        <p id="form-error" class="hidden text-sm text-red-600"></p>
      </form>

      <div id="success" class="hidden">
        <h2 class="text-xl font-semibold text-ink-900">Booking confirmed</h2>
        <p id="success-detail" class="mt-2 text-sm text-ink-600"></p>
        <p class="mt-3 text-sm text-ink-600">A cancellation link is included below in case you need it.</p>
        <p id="success-cancel" class="mt-1 break-all text-xs text-ink-500"></p>
      </div>
    </div>
  </section>
</MarketingLayout>

<script is:inline define:vars={{ API_BASE, INSTALL_ID, SLUG }}>
  (function () {
    const visitorTz = Intl.DateTimeFormat().resolvedOptions().timeZone || 'UTC';
    const statusEl = document.getElementById('booking-status');
    const pickerEl = document.getElementById('picker');
    const dateListEl = document.getElementById('date-list');
    const timeGridEl = document.getElementById('time-grid');
    const formEl = document.getElementById('confirm-form');
    const selectedLabelEl = document.getElementById('selected-label');
    const confirmBtn = document.getElementById('confirm-btn');
    const formError = document.getElementById('form-error');
    const successEl = document.getElementById('success');
    const successDetailEl = document.getElementById('success-detail');
    const successCancelEl = document.getElementById('success-cancel');

    let slotsByDate = new Map();
    let selectedSlot = null;
    let selectedDate = null;

    function ymdInTz(date, tz) {
      const parts = new Intl.DateTimeFormat('en-CA', {
        timeZone: tz, year: 'numeric', month: '2-digit', day: '2-digit',
      }).formatToParts(date);
      return `${parts.find(p => p.type === 'year').value}-${parts.find(p => p.type === 'month').value}-${parts.find(p => p.type === 'day').value}`;
    }

    function fmtDate(ymd) {
      const [y, m, d] = ymd.split('-').map(Number);
      const dt = new Date(Date.UTC(y, m - 1, d, 12));
      return new Intl.DateTimeFormat(undefined, { timeZone: visitorTz, weekday: 'short', month: 'short', day: 'numeric' }).format(dt);
    }

    function fmtTime(iso) {
      return new Intl.DateTimeFormat(undefined, { timeZone: visitorTz, hour: 'numeric', minute: '2-digit' }).format(new Date(iso));
    }

    function fmtFull(iso) {
      return new Intl.DateTimeFormat(undefined, {
        timeZone: visitorTz, weekday: 'long', year: 'numeric', month: 'long', day: 'numeric', hour: 'numeric', minute: '2-digit', timeZoneName: 'short',
      }).format(new Date(iso));
    }

    async function loadSlots() {
      try {
        const now = new Date();
        const from = ymdInTz(now, visitorTz);
        const toDate = new Date(now.getTime() + 21 * 24 * 60 * 60 * 1000);
        const to = ymdInTz(toDate, visitorTz);
        const url = `${API_BASE}/api/public/bookings/${encodeURIComponent(INSTALL_ID)}/${encodeURIComponent(SLUG)}/slots?from=${from}&to=${to}&tz=${encodeURIComponent(visitorTz)}`;
        const res = await fetch(url);
        if (!res.ok) throw new Error(`Failed to load availability (${res.status})`);
        const json = await res.json();
        if (!json.slots || json.slots.length === 0) {
          statusEl.textContent = 'No availability in the next 21 days. Please check back later.';
          return;
        }
        slotsByDate = new Map();
        for (const s of json.slots) {
          const k = ymdInTz(new Date(s.starts_at), visitorTz);
          if (!slotsByDate.has(k)) slotsByDate.set(k, []);
          slotsByDate.get(k).push(s);
        }
        statusEl.classList.add('hidden');
        pickerEl.classList.remove('hidden');
        renderDates();
      } catch (e) {
        statusEl.textContent = e.message || 'Failed to load availability';
      }
    }

    function renderDates() {
      const dates = Array.from(slotsByDate.keys()).sort();
      dateListEl.innerHTML = '';
      for (const dk of dates) {
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.textContent = fmtDate(dk);
        btn.className = 'rounded-lg border border-ink-200 px-3 py-2 text-left text-sm text-ink-700 hover:border-brand-blue-500 hover:bg-brand-blue-50';
        if (dk === selectedDate) btn.className += ' border-brand-blue-500 bg-brand-blue-50 font-semibold';
        btn.addEventListener('click', () => {
          selectedDate = dk;
          selectedSlot = null;
          renderDates();
          renderTimes();
        });
        dateListEl.appendChild(btn);
      }
      if (!selectedDate && dates.length > 0) {
        selectedDate = dates[0];
        renderDates();
        renderTimes();
      }
    }

    function renderTimes() {
      timeGridEl.innerHTML = '';
      const slots = (selectedDate && slotsByDate.get(selectedDate)) || [];
      for (const s of slots) {
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.textContent = fmtTime(s.starts_at);
        btn.className = 'rounded-lg border border-ink-200 px-3 py-2 text-sm text-ink-700 hover:border-brand-blue-500 hover:bg-brand-blue-50';
        if (selectedSlot && selectedSlot.starts_at === s.starts_at) btn.className += ' border-brand-blue-500 bg-brand-blue-50 font-semibold';
        btn.addEventListener('click', () => {
          selectedSlot = s;
          renderTimes();
          formEl.classList.remove('hidden');
          selectedLabelEl.textContent = fmtFull(s.starts_at);
        });
        timeGridEl.appendChild(btn);
      }
    }

    formEl.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!selectedSlot) return;
      formError.classList.add('hidden');
      confirmBtn.disabled = true;
      confirmBtn.textContent = 'Confirming...';
      try {
        const fd = new FormData(formEl);
        const body = {
          starts_at: selectedSlot.starts_at,
          ends_at: selectedSlot.ends_at,
          attendee: { name: fd.get('name'), email: fd.get('email'), tz: visitorTz },
          notes: fd.get('notes') || null,
        };
        const res = await fetch(
          `${API_BASE}/api/public/bookings/${encodeURIComponent(INSTALL_ID)}/${encodeURIComponent(SLUG)}/reserve`,
          { method: 'POST', headers: { 'content-type': 'application/json' }, body: JSON.stringify(body) },
        );
        const json = await res.json().catch(() => ({}));
        if (res.status === 409) {
          formError.textContent = 'That slot was just taken. Pick another time.';
          formError.classList.remove('hidden');
          selectedSlot = null;
          formEl.classList.add('hidden');
          await loadSlots();
          return;
        }
        if (!res.ok) throw new Error(json.error || `Reservation failed (${res.status})`);
        pickerEl.classList.add('hidden');
        formEl.classList.add('hidden');
        successEl.classList.remove('hidden');
        successDetailEl.textContent = `Confirmed for ${fmtFull(json.starts_at)}.`;
        if (json.cancel_url) successCancelEl.textContent = `Cancel link: ${json.cancel_url}`;
      } catch (err) {
        formError.textContent = err.message || 'Reservation failed';
        formError.classList.remove('hidden');
      } finally {
        confirmBtn.disabled = false;
        confirmBtn.textContent = 'Confirm booking';
      }
    });

    loadSlots();
  })();
</script>
